# Ligretto deploy env (Compose auto-loads .env). Co-locate on the platform network (see the override).
# Copy to .env and fill the M2M secret + DB password.

DOMAIN=aangifteportal.nl
PUBLIC_APP_URL=https://ligretto.${DOMAIN}

# Platform issuer (PUBLIC — the `iss` the browser token carries). The internal call URLs are set in the
# override for co-locate.
PLATFORM_LOGIN_API_URL=https://auth.${DOMAIN}
PLATFORM_AUTH_API_URL=https://auth-api.${DOMAIN}
PLATFORM_LOGS_API_URL=https://logs-api.${DOMAIN}

# M2M service account (server-side only) — reuse DAC9's or create your own (role: users:read, logs:write).
M2M_CLIENT_ID=
M2M_CLIENT_SECRET=

# App DB on the platform's MySQL. The `ligretto` database + user already exist; co-locate reaches MySQL
# as mysql:3306. Put the ligretto user's password here.
DATABASE_URL=mysql+pymysql://ligretto:CHANGE_ME@mysql:3306/ligretto
