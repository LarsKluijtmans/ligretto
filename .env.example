# Ligretto deploy env (Compose auto-loads .env). Co-locate on the platform network (see the override).
# Copy to .env and fill the M2M secret + DB password.
#
# TWO domains, kept SEPARATE on purpose:
#   - APP_DOMAIN   = where THIS app is served (frontend + its API subdomain).
#   - PLATFORM_*   = where the AUTH PLATFORM lives (login/auth/logs). This is the `iss` the browser
#                    token carries, so the backend validates tokens against it (TOKEN_ISSUER).
# They are the SAME only when the app is co-located on the platform's domain. If the app moves to its
# own domain (e.g. larskluijtmans.com) the PLATFORM_* URLs MUST still point at the platform's domain —
# do NOT derive them from APP_DOMAIN, or the backend rejects every token with "Invalid issuer".

APP_DOMAIN=larskluijtmans.com
PUBLIC_APP_URL=https://ligretto.${APP_DOMAIN}

# Platform issuer (PUBLIC — the `iss` the browser token carries). Point at the AUTH PLATFORM's domain,
# NOT ${APP_DOMAIN}. The internal call URLs are set in the override for co-locate.
PLATFORM_LOGIN_API_URL=https://auth.aangifteportal.nl
PLATFORM_AUTH_API_URL=https://auth-api.aangifteportal.nl
PLATFORM_LOGS_API_URL=https://logs-api.aangifteportal.nl

# M2M service account (server-side only) — reuse DAC9's or create your own (role: users:read, logs:write).
M2M_CLIENT_ID=
M2M_CLIENT_SECRET=

# App DB on the platform's MySQL. The `ligretto` database + user already exist; co-locate reaches MySQL
# as mysql:3306. Put the ligretto user's password here.
DATABASE_URL=mysql+pymysql://ligretto:CHANGE_ME@mysql:3306/ligretto

# Ligretto's OWN Cloudflare tunnel token (larskluijtmans.com). SECRET — set in .env, never commit.
# TUNNEL_TOKEN=
