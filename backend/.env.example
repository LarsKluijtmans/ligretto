APP_NAME=ligretto

# ============================================================================
# PLATFORM URLs — the single place to change to point Ligretto at another auth
# platform deployment. Defaults below target the live platform (aangifteportal.nl).
# Local platform instead: LOGIN_API_URL=http://127.0.0.1:8010, AUTH_API_URL=
# http://127.0.0.1:8050, LOGS_API_URL=http://127.0.0.1:8030, TOKEN_ISSUER=
# http://127.0.0.1:8010.
# ============================================================================
LOGIN_API_URL=https://auth.aangifteportal.nl
AUTH_API_URL=https://auth-api.aangifteportal.nl
LOGS_API_URL=https://logs-api.aangifteportal.nl
TOKEN_ISSUER=https://auth.aangifteportal.nl

# ---- M2M service account (SERVER-SIDE ONLY — never put these in the frontend) ----
# A client_credentials client whose RBAC role grants users:read + logs:write.
# Reuse the DAC9 service account or create your own in the console.
M2M_CLIENT_ID=
M2M_CLIENT_SECRET=

ENABLE_ENRICHMENT=true
ENABLE_PROJECT_LOGGING=true
LOG_CATEGORY=ligretto
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# App database (games / players / scores / history). SQLite for dev; MySQL for prod, e.g.
# mysql+pymysql://user:pass@host:3306/ligretto
DATABASE_URL=sqlite:///./ligretto.db
