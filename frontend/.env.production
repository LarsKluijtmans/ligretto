# Production build-time values (Vite auto-loads this for `npm run build`; `npm run dev` uses .env).
# Public values only — no secrets. Same-origin: VITE_BACKEND_URL is the app's OWN public origin, so the
# SPA calls https://ligretto.aangifteportal.nl/api/* and nginx proxies /api to the backend container.

VITE_LOGIN_API_URL=https://auth.aangifteportal.nl
VITE_LOGIN_CLIENT_ID=client_1laEUpaEk6Ag3M6K7taKJ4CR
VITE_REDIRECT_URI=https://ligretto.aangifteportal.nl/
VITE_BACKEND_URL=https://ligretto.aangifteportal.nl
