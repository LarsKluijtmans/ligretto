# Ligretto frontend (React/Vite) — BROWSER-VISIBLE values only. No secrets (PKCE client is public).

# Login API base — change to swap platforms (dev local platform: http://127.0.0.1:8010).
VITE_LOGIN_API_URL=https://auth.aangifteportal.nl

# Public login client id (PKCE). Reuse the DAC9 client or create your own on the target project.
VITE_LOGIN_CLIENT_ID=

# Must EXACTLY match a redirect_uri registered on the login client (and an allowed project origin).
# Dev server default:
VITE_REDIRECT_URI=http://localhost:5173/

# This app's own backend.
VITE_BACKEND_URL=http://127.0.0.1:9000
